# backend/.env.example -- copy to backend/.env and fill in. NEVER commit .env.

# --- JWT signing secret ------------------------------------------------------
# Any long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Left blank, the app runs on a PUBLIC development key that anyone could use to
# forge a login token. Fine locally; never for a real deployment.
JWT_SECRET=

# --- deployment mode ---------------------------------------------------------
# Set to "production" to make the app REFUSE to start on the development
# signing key above, rather than silently accepting forgeable tokens.
SUPPORTBOT_ENV=

# --- Gmail (OPTIONAL) --------------------------------------------------------
# Leave BOTH blank to run in console mode (codes print to the terminal).
# To send real email, use a Gmail APP PASSWORD (needs 2-Step Verification on):
#   Google Account -> Security -> App passwords -> Mail
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
