# backend/.env.example -- copy to backend/.env and fill in. NEVER commit .env.

# --- JWT signing secret ------------------------------------------------------
# Any long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# --- Gmail (OPTIONAL) --------------------------------------------------------
# Leave BOTH blank to run in console mode (codes print to the terminal).
# To send real email, use a Gmail APP PASSWORD (needs 2-Step Verification on):
#   Google Account -> Security -> App passwords -> Mail
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
